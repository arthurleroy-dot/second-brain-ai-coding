# Clé LiteLLM (proxy compatible Anthropic)
ANTHROPIC_API_KEY=
# URL du proxy LiteLLM (ex: https://litellm.mondomaine.com)
ANTHROPIC_BASE_URL=
# Nom du modèle exposé par le proxy (ajuster si différent)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase (optionnel : si absent, le chat répond sans persister l'historique)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Racine du wiki/raw sur le disque (optionnel).
# Par défaut, l'app remonte d'un cran depuis /web vers la racine du dépôt.
# WIKI_ROOT=/chemin/absolu/vers/wiki
# RAW_ROOT=/chemin/absolu/vers/raw
