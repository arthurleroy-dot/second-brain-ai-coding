# Clé LiteLLM (proxy compatible Anthropic)
ANTHROPIC_API_KEY=
# URL du proxy LiteLLM (ex: https://litellm.mondomaine.com)
ANTHROPIC_BASE_URL=
# Nom du modèle exposé par le proxy (ajuster si différent)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase — source de vérité unique (requis).
# URL + clé anon (lecture côté navigateur), clé service role (opérations serveur).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Racine du wiki sur le disque (utilisé UNIQUEMENT par le script de migration).
# WIKI_ROOT=/chemin/absolu/vers/wiki
